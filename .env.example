# ─── Gemini AI Personalization ─────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gmail API ─────────────────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Your Gmail address (emails will be sent FROM this address)
SENDER_EMAIL=your.email@gmail.com

# ─── App Settings ──────────────────────────────────────────────────────────────
# Set to "true" during testing — emails are logged but NOT sent
SFAO_DRY_RUN=true

# Flask dashboard secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change_me_to_a_random_string

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///sfao.db

# ─── Attachments ───────────────────────────────────────────────────────────────
# Place your resume PDF at this path before first run
RESUME_PATH=attachments/resume.pdf
